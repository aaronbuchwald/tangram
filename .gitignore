# Environment variables / secrets
.env
.env.*
!.env.example

# Persisted browser-automation sessions are AUTH BEARERS (cookies/storageState
# + persistent profiles). They live OUTSIDE the repo by default
# (~/.tangram-automation/profiles/<site>/); this is a belt-and-suspenders block
# in case one is ever rooted under the tree. See crates/tangram-automation/src/session.rs.
.tangram-automation/
**/storage-state.json
**/user-data/

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Build artifacts and dependencies
node_modules/
.wrangler/
dist/
# Exception (ADR-0007): the tangram shell app's built UI is COMMITTED — the
# host serves it as the app's static UI dir and `cargo run -p tangram-host`
# must work without a Node toolchain. CI rebuilds it and fails if it is stale.
!apps/tangram/ui/dist/
build/
out/
target/
bin/
*.o
*.exe

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Coverage / test output
coverage/
*.cover
.coverage


# Added by cargo

/target

# Tangram runtime data (replicated document files)
data/
data-*/

# Claude Code local state (skills live in .agents/skills/; the committed
# .claude/skills is a symlink to it)
.claude/worktrees/
.claude/settings.local.json
