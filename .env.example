# Copy to .env and adjust. .env is gitignored — never commit secrets.

# Address the server listens on. Use 0.0.0.0:8080 to expose beyond localhost.
BIND_ADDR=127.0.0.1:8080

# Peer instance to replicate with (optional — apps are fully local without it).
#TANGRAM_REMOTE=ws://other-host:8080/sync

# Where the replicated document lives.
#TANGRAM_DATA_DIR=data

# CSP frame-ancestors controlling iframe embedding ("*" = any host; lock down
# for shared deployments, e.g.: FRAME_ANCESTORS='self' app://obsidian.md).
FRAME_ANCESTORS=*

# Log filter.
RUST_LOG=info
