# Copy to .env and adjust. .env is gitignored — never commit secrets.

# Address the server listens on. Use 0.0.0.0:8080 to expose beyond localhost.
BIND_ADDR=127.0.0.1:8080

# CSP frame-ancestors value controlling which hosts may embed the UI in an
# iframe. "*" allows any host (fine for local dev). Lock down for shared
# deployments, e.g.: FRAME_ANCESTORS='self' app://obsidian.md
FRAME_ANCESTORS=*

# Log filter (tracing_subscriber EnvFilter syntax).
RUST_LOG=info,tower_http=debug
